{
  "name": "bwise-dental-desktop",
  "version": "1.0.0",
  "description": "BWISE Dental Desktop — Aplicación instalable offline-first basada en Electron, React y SQLite.",
  "author": "KIGSOFT Technology",
  "license": "MIT",
  "main": "app/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:backend\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:backend": "cross-env NODE_ENV=development node ./core/src/server.js",
    "dev:renderer": "cross-env NODE_ENV=development vite --config ./vite.config.js",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "build": "cross-env NODE_ENV=production vite build && electron-builder",
    "clean": "rimraf app/renderer/dist build",
    "start": "electron ."
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "axios": "^1.12.2",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "electron": "^38.2.2",
    "express": "^5.1.0",
    "framer-motion": "^12.23.24",
    "keytar": "^7.9.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.545.0",
    "react": "^19.2.3",
    "react-cropper": "^2.3.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.9.4",
    "react-tailwindcss-datepicker": "^2.0.0",
    "react-zoom-pan-pinch": "^3.7.0",
    "recharts": "^3.4.1",
    "sequelize": "^6.37.7",
    "socket.io-client": "^4.8.1",
    "sqlite3": "^5.1.7",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "electron-builder": "^26.0.12",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.14",
    "vite": "^7.1.10"
  },
  "build": {
    "appId": "com.mirai.pos",
    "productName": "Mirai POS Desktop",
    "directories": {
      "output": "build"
    },
    "files": [
      "app/main/**/*",
      "app/renderer/dist/**/*",
      "core/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "core/",
        "to": "core/"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
